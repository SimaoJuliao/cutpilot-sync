{
  "name": "cutpilot-sync",
  "version": "1.0.0",
  "description": "CutPilot Sync — AI-powered video editor: transcribe, cut, render",
  "author": {
    "name": "Simão Julião",
    "email": "cutpilotsync@gmail.com"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "start": "electron-vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.106.2",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "form-data": "^4.0.0",
    "lucide-react": "^1.16.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.cutpilotsync.app",
    "productName": "CutPilot Sync",
    "icon": "build/icon",
    "protocols": [
      {
        "name": "CutPilot Sync",
        "schemes": [
          "cutpilotsync"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "SimaoJuliao",
      "repo": "cutpilot-sync",
      "releaseType": "release"
    },
    "extraResources": [],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ]
  }
}
