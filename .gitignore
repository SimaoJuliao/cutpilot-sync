# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.remember/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# .env.example is intentionally NOT ignored — it's a safe template

# ── Build outputs (electron-vite) ─────────────────────────────────────────────
out/

# ── Packaged app (electron-builder) ───────────────────────────────────────────
dist/
dist-electron/
release/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo

# ── Vite / misc cache ─────────────────────────────────────────────────────────
.vite/
.cache/

# ── Electron builder artifacts ────────────────────────────────────────────────
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.zip
*.tar.gz
